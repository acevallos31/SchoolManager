{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",

    "types": []

    "types": [
      "node"
    ]

  },
  "files": [
    "src/main.ts",
    "src/polyfills.ts"
  ],
  "include": [

    "src/**/*.d.ts",
    "src/**/*.ts"

    "src/**/*.d.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts"
  ]
}
