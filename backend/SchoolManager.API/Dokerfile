FROM ://microsoft.com AS build
WORKDIR /src

# Copia los archivos usando la ruta interna del contenedor
COPY ["SchoolManager.API.csproj", "."]
RUN dotnet restore "./SchoolManager.API.csproj"

COPY . .
RUN dotnet publish "SchoolManager.API.csproj" -c Release -o /app/publish /p:UseAppHost=false

FROM ://microsoft.com AS final
WORKDIR /app
COPY --from=build /app/publish .

# Render expone la variable $PORT de forma dinámica, este comando la vincula correctamente
ENTRYPOINT ["sh", "-c", "dotnet SchoolManager.API.dll --urls http://0.0.0:${PORT:-8080}"]
